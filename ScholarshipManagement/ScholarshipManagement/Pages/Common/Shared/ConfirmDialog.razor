@using MudBlazor
@using MudBlazor.Components

<style>
    .confirm-dialog-btn {
        background-color: #0080ff;
        color: white;
        border-radius: 6px;
        padding: 8px 16px;
        border: 1px solid #0080ff;
        font-family: Inter, sans-serif;
        font-weight: 700;
        font-size: 9pt;
        cursor: pointer;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        transition: all 0.2s ease;
        width: 70px; /* ← fixed width */
        text-align: center; /* keeps text centered */
    }
    
    
    .confirm-dialog-btn:hover {
        background-color: #006be0;
        border-color: #006be0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.25);
    }


    .delete-dialog-btn {
        background-color: #dc3545; /* Bootstrap danger red */
        color: white;
        border-radius: 6px;
        padding: 8px 16px;
        border: 1px solid #dc3545;
        font-family: Inter, sans-serif;
        font-weight: 700;
        font-size: 9pt;
        cursor: pointer;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        transition: all 0.2s ease;
        width: 70px; /* same width */
        text-align: center;
    }
    
    .delete-dialog-btn:hover {
        background-color: #b02a37; /* darker red */
        border-color: #b02a37;
        box-shadow: 0 4px 10px rgba(0,0,0,0.25);
    }

</style>

<MudDialog>
    <DialogContent>
        <MudText>@Message</MudText>
    </DialogContent>

    <DialogActions>
        <div class="d-flex justify-end gap-2" style="margin:5px;">
            <button @onclick="Confirm" class="delete-dialog-btn" type="button">Delete</button>
            <button @onclick="Cancel" class="confirm-dialog-btn" type="button">Cancel</button>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Message { get; set; } = string.Empty;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}

