@* @page "/login-page"
@attribute [AllowAnonymous]


@layout EmptyLayout
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using ScholarshipManagement.DTOs.Common
@using ScholarshipManagement.DTOs.Common.Auth
@using ScholarshipManagement.Helper
@using ScholarshipManagement.Helper.Enums
@using ScholarshipManagement.Helper.Translations
@using ScholarshipManagement.Services.Common
@using static ScholarshipManagement.Helper.Constant
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject AuthService AuthService
@inject CustomAuthStateProvider AuthStateProvider
@inject TranslationManager TranslationManager

<style>
    .login-page {
        height: 100vh;
        width: 100%;
    }

    /* GRID */
    .full-height {
        height: 100%;
    }

    /* LEFT SIDE */
    .login-left {
        background: linear-gradient(135deg, #5a73ff, #7c8cff);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* CONTENT */
    .left-content {
        width: 80%;
        max-width: 420px;
        text-align: center;
    }

    /* BRAND */
    .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        justify-content: center;
        margin-bottom: 40px;
    }

    .logo {
        width: 50px;
        height: 50px;
        border-radius: 50%;
    }

    /* IMAGE */
    .hero-img {
        width: 100%;
        max-width: 260px;
        margin: 30px auto;
    }

    /* RIGHT SIDE */
    .login-right {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
    }

    /* FORM */
    .form-container {
        width: 100%;
        max-width: 400px;
    }

    /* DIVIDER */
    .divider {
        margin: 20px 0;
        font-size: 14px;
        opacity: 0.9;
    }

    /* NOTE */
    .note {
        font-size: 12px;
        opacity: 0.7;
        margin-top: 10px;
    }

    /* SOCIAL (your existing works too) */
    .social-login {
        display: flex;
        justify-content: center;
        gap: 14px;
    }

</style>



<div class="login-page">

    <MudGrid Class="full-height">

        <!-- 🔵 LEFT SIDE -->
        <MudItem xs="12" md="6" Class="login-left">

            <div class="left-content">

                <!-- BRAND -->
                <div class="brand">
                    <img src="Images/kafat-logo.jpg" class="logo" />
                    <div>
                        <h2>Kafa’at</h2>
                        <p>Program Platform for Higher Education</p>
                    </div>
                </div>

                <!-- IMAGE -->
                <img src="images/profile-img.png" class="hero-img" />

                <!-- BOTTOM -->
                <div class="bottom-section">

                    <div class="divider">Or Sign Up With</div>

                    <div class="social-login">
                        <MudIconButton Icon="@Icons.Material.Filled.MarkEmailUnread"
                                       Class="social-circle"
                                       OnClick="LoginWithCode" />

                        <MudIconButton Icon="@Icons.Custom.Brands.Google"
                                       Class="social-circle" />
                    </div>

                    <p class="note">
                        Note: Internet Explorer is an unsupported browser.
                        Open in Chrome, Mozilla or Safari.
                    </p>

                </div>

            </div>

        </MudItem>


        <!-- ⚪ RIGHT SIDE -->
        <MudItem xs="12" md="6" Class="login-right">

            <div class="form-container">

                <MudForm @ref="form" Model="model">

                    <MudText Typo="Typo.h5" Class="mb-6">Login</MudText>

                    <!-- USERNAME -->
                    <MudText Typo="Typo.subtitle2">Username</MudText>
                    <MudTextField @bind-Value="model.LoginName"
                                  Placeholder="Enter username"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person"
                                  Dense="true" Class="mud-width-full" />

                    <!-- PASSWORD -->
                    <MudText Typo="Typo.subtitle2" Class="mt-4">Password</MudText>
                    <MudTextField @bind-Value="model.Password"
                                  Placeholder="Enter password"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  InputType="@(showPassword? InputType.Text: InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(showPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="TogglePassword"
                                  Dense="true" Class="mud-width-full" />

                    <!-- OPTIONS -->
                    <div class="d-flex justify-space-between mt-4">
                        <MudCheckBox @bind-Value="model.RememberMe" Label="Remember me" />
                        <div>
                            <MudLink Href="@Routes.ForgotUserName">Forgot username?</MudLink>
                            <span> • </span>
                            <MudLink Href="@Routes.ForgotPassword">Forgot password?</MudLink>
                        </div>
                    </div>

                    <!-- LOGIN BTN -->
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mud-width-full mt-6"
                               Size="Size.Large"
                               Disabled="@isBusy"
                               OnClick="SignIn">

                        @if (isBusy)
                        {
                            <MudProgressCircular Indeterminate Size="Size.Small" Class="me-2" />
                            <span>Signing in...</span>
                        }
                        else
                        {
                            <span>Log In</span>
                        }

                    </MudButton>

                    <MudDivider Class="my-4" />

                    <!-- SIGNUP -->
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               Class="mud-width-full"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.School"
                               OnClick="GoToSignup">
                        Schools — Sign up now
                    </MudButton>

                </MudForm>

            </div>

        </MudItem>

    </MudGrid>

</div>



@code {
    private MudForm? form;
    private readonly LoginRequestDto model = new();
    private bool showPassword;
    private bool isBusy;


    protected override async Task OnInitializedAsync()
    {
        var isLoggedIn = await AuthService.IsUserLoggedIn();

        if (isLoggedIn)
        {
            Nav.NavigateTo(Routes.Dashboard, replace: true);
        }
    }


    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    private async Task SignIn()
    {
        await form!.Validate();

        if (!form.IsValid)
            return;

        isBusy = true;
        //StateHasChanged();

        var ok = await AuthService.Login(model);
        if (ok.Success)
        {
            AuthStateProvider.NotifyLogin();
            await TranslationManager.Load(LanguageCode.En);

            Nav.NavigateTo(Routes.Dashboard);
        }
        else
        {
            Snackbar.Add(ok.Message, Severity.Error);
        }

        isBusy = false;

    }

    private void GoToSignup()
    {
        Nav.NavigateTo(Routes.SchoolRegistration);
    }

    private void GoToSignupUniversity()
    {
        Nav.NavigateTo(Routes.SchoolRegistration);
    }



    private sealed class LoginNewModel
    {
        public string? Username { get; set; }
        public string? Password { get; set; }
        public bool RememberMe { get; set; }
    }


    private void LoginWithCode()
    {
        Nav.NavigateTo(Routes.LoginWithCode);
    }

}
 *@
