@page "/reset-password"
@attribute [AllowAnonymous]


@layout EmptyLayout
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using ScholarshipManagement.DTOs.Common
@using ScholarshipManagement.DTOs.Common.Auth
@using ScholarshipManagement.Helper
@using ScholarshipManagement.Services.Common
@using static ScholarshipManagement.Helper.Constant
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject AuthService AuthService
@inject CustomAuthStateProvider AuthStateProvider


<style>
    .login-shell {
        border-radius: 16px;
        overflow: hidden;
        background: white;
    }

    .login-hero {
        background: linear-gradient(135deg, rgba(90, 115, 255, 0.18) 0%, rgba(90, 115, 255, 0.06) 55%, rgba(0, 0, 0, 0) 100%);
    }

    .login-hero-img {
        max-width: 240px;
        height: auto;
        object-fit: contain;
    }

    .login-content {
        background: white;
    }

    .login-avatar {
        box-shadow: 0 10px 24px rgba(45, 55, 72, 0.18);
    }

    .tight-icon-btn .mud-button-icon-start {
        margin-right: 0px !important;
    }

</style>


<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-center">
    <MudPaper Elevation="0" Outlined="true" Class="login-shell my-12 mud-width-full">

        <div class="login-hero pa-6 pa-sm-8">
            <div class="d-flex align-center justify-space-between gap-4">
                <img src="Images/kafat-logo.jpg"
                     alt="Menu" style=" height:50px; width:50px;
                         border-radius:50%; object-fit:cover;border:2px solid white;" class="login-avatar" />
                <div>
                    <MudText Typo="Typo.h5" Class="mud-text-primary">Kafa’at</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">Program Platform for Higher Education</MudText>
                </div>
                <img class="login-hero-img" src="images/profile-img.png" alt="Hero" />
            </div>
        </div>

        <div class="login-content pa-6 pa-sm-8">

            <MudForm @ref="form" Model="model">

                <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">New Password</MudText>
                <MudTextField @bind-Value="model.NewPassword"
                              Placeholder="Enter new password"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Password is required"
                              InputType="@(showPassword? InputType.Text: InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(showPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              IconSize="Size.Small"
                              OnAdornmentClick="TogglePassword"
                              Class="mud-width-full" Dense="true" Margin="Margin.Dense" />


                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Class="mud-width-full mt-6"
                           Size="Size.Large"
                           Disabled="@isBusy"
                           OnClick="Resetpassword">
                    @if (isBusy)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
                        <span>Resetting...</span>
                    }
                    else
                    {
                        <span>Reset Password</span>
                    }
                </MudButton>

                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Class="mud-width-full mt-3 tight-icon-btn"
                           StartIcon="@Icons.Material.Filled.ArrowBackIos"
                           IconSize="Size.Small"
                           OnClick="GoToLogin">
                    Back to Login
                </MudButton>



                <MudDivider Class="mt-5" />

                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-6 d-block text-center">
                    Create a new password for your account. For security reasons, choose a strong and unique password.
                </MudText>

            </MudForm>

        </div>

    </MudPaper>
</MudContainer>



@code {

    private MudForm? form;
    private bool isBusy;

    private ResetPasswordRequestDto model = new ResetPasswordRequestDto();

    [Parameter]
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }


    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            Snackbar.Add("Invalid or expired reset link.", Severity.Error);
        }
        else
        {
            model.Token = Token;
        }
    }

    private bool showPassword;
    private void TogglePassword()
    {
        showPassword = !showPassword;
    }



    private async Task Resetpassword()
    {
        await form!.Validate();

        if (!form.IsValid)
            return;

        isBusy = true;
        StateHasChanged();

        var ok = await AuthService.ResetPassword(model);

        if (ok.Success)
        {
            Snackbar.Add(ok.Message, Severity.Success);
        }
        else
        {
            Snackbar.Add(ok.Message, Severity.Error);
        }

        isBusy = false;
    }


    private void GoToLogin()
    {
        Nav.NavigateTo(Routes.Login);
    }




}
