@page "/home"
@page "/dashboard"
@attribute [Authorize]

@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using ScholarshipManagement.DTOs.Common.Settings
@using ScholarshipManagement.DTOs.School.Students
@using ScholarshipManagement.DTOs.University.CourseRequirement
@using ScholarshipManagement.Helper.Enums
@using ScholarshipManagement.Helper.Translations
@using ScholarshipManagement.Services.Common
@using Color = MudBlazor.Color
@using ScholarshipManagement.Services.School
@using ScholarshipManagement.Services.University
@using Size = MudBlazor.Size
@using static ScholarshipManagement.Helper.Constant
@inject CommonService CommonService
@inject StudentService StudentService
@inject CourseRequirementService CourseRequirementService
@inject CurrentUserProfileService CurrentUserProfileService
@inject AuthService AuthService
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject TranslationStateService T
@inject TranslationStateService TState
@inject NavigationManager NavManager

<style>
    .dashboard-card {
        border-radius: 12px;
        height: 110px;
        transition: 0.2s;
    }

        .dashboard-card:hover {
            transform: translateY(-4px);
            transition: 0.2s;
        }


    .success {
    background: rgba(22, 163, 74, 0.15);
    color: #16a34a;
    border: 1px solid rgba(22, 163, 74, 0.25);
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 12px rgba(22, 163, 74, 0.15);
}

.info {
    background: rgba(37, 99, 235, 0.15);
    color: #2563eb;
    border: 1px solid rgba(37, 99, 235, 0.25);
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
}

.warning {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.25);
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.15);
}

.danger {
    background: rgba(220, 38, 38, 0.15);
    color: #dc2626;
    border: 1px solid rgba(220, 38, 38, 0.25);
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.15);
}


    .card-title {
        font-size: 13px;
        opacity: 0.8;
    }

    .card-value {
        font-size: 26px;
        font-weight: bold;
    }

    .card-sub {
        font-size: 11px;
        opacity: 0.7;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 10px;
    }
</style>




<style>
    .contact-compact {
        display: flex;
        flex-direction: column;
        gap: 2px;
        font-size: 13px;
        line-height: 1.2;
    }

    .contact-line {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .contact-icon {
        font-size: 13px !important;
    }

        .contact-icon.office {
            color: #2563eb;
        }

        .contact-icon.email {
            color: #ef4444;
        }

        .contact-icon.phone {
            color: #22c55e;
        }

    .contact-text {
        color: #6b7280;
        text-decoration: none;
        font-size: 13px;
        max-width: 230px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

        .contact-text:hover {
            text-decoration: underline;
        }

    .contact-empty {
        font-size: 13px;
        color: #9ca3af;
        font-style: italic;
    }





    .table-header {
        font-weight: 700; /* 🔥 more bold */
        font-size: 14px; /* slightly bigger */
        color: #111827; /* darker text */
        background-color: #f1f5f9; /* subtle contrast */
        /* border-bottom: 2px solid #d1d5db; */
    }

</style>




<!-- Main Content Wrapper -->
<div style="display: flex; flex-direction: column; align-items: flex-start; flex: 1 0 0;">

    <!-- Page Top Section (Header area) -->
    <div style="display: flex; flex-direction: column; align-items: center; align-self: stretch;">

        <!-- Section Title Bar (under Page Top) -->
        <div style="display: flex; height: 64px; justify-content: space-between; align-items: center;
                    align-self: stretch; border-bottom: 1px solid var(--color-border-horizontal-lines, #DBDBDB);
                    background: var(--color-background-main, #FFF);">

            <!-- Left Section (Inside Page Title Bar) -->
            <div style="display: flex; height: 64px; padding: 0 26px; align-items: center;">

                <div style="display: flex; align-items: center;">


                    @* <span class="page-title">
                        @T.T("Dashboard")
                    </span> *@

                    <span class="page-title page-title-uppercase">
                        @T.T("Dashboard")
                    </span>

                </div>

            </div>

            <!-- Right Section (Inside Page Title Bar) -->
            <div style="display: flex; padding: 0 24px; justify-content: flex-end; align-items: center; gap: 14px;">
                <span style="color: var(--color-text-breadcrumbs, #000); font-family: Inter, sans-serif;
                            font-size: 15px; font-style: normal; font-weight: 400; line-height: 20px;
                            text-transform: capitalize; margin-right:25px">
                    @* Total Records : <span id="totalRecords">@TotalRecords</span> *@
                </span>
            </div>

        </div>

    </div>

    <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">

        <!-- KPI CARDS -->
        <MudGrid Class="mb-4">

            @foreach (var card in DashboardCards)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class=@($"pa-4 d-flex align-center justify-space-between dashboard-card {card.Color}")
                              Style="cursor:pointer"
                              @onclick="() => Navigate(card.Url)">

                        <div>
                            <div class="card-title">@card.Title</div>
                            <div class="card-value">@card.Value</div>

                            @if (card.GrowthPercentage != null)
                            {
                                <div class="card-sub">
                                    @(card.GrowthPercentage > 0
                                                                ? $"+{Math.Round(card.GrowthPercentage.Value, 1)}%"
                                                                : $"{Math.Round(card.GrowthPercentage.Value, 1)}%")
                                </div>
                            }
                            else
                            {
                                <div class="card-sub">—</div>
                            }
                        </div>

                        <MudIcon Icon="@GetMudIcon(card.Icon)" Size="Size.Large" />

                    </MudPaper>
                </MudItem>
            }

        </MudGrid>

        <!-- TABLES -->
        <MudGrid>

            <!-- Recent Students -->
            <MudItem xs="12">
                <MudPaper Class="pa-4">
                    <div class="section-title">Recent Students</div>

                    <MudTable Items="RecentStudents" Dense Hover>
                        <HeaderContent>
                            <MudTh Class="table-header">Name</MudTh>
                            <MudTh Class="table-header">Contact Information</MudTh>
                            <MudTh Class="table-header">Created Info</MudTh>
                            <MudTh Class="table-header">Action</MudTh>
                        </HeaderContent>

                        <RowTemplate>

                            <MudTd>
                                <div class="d-flex align-items-center gap-3">

                                    <!-- Std Photo -->
                                    <img src="@(string.IsNullOrEmpty(context.Photo) ? "/images/male-icon.png" : context.Photo)"
                                         alt="Student Photo"
                                         style="width:35px;height:35px;border-radius:50%;object-fit:cover;border:1px solid #e0e0e0;" />

                                    <!-- Std Details -->
                                    <div class="flex-grow-1">

                                        <!-- Clickable Full Name -->
                                        <div class="fw-bold text-primary"
                                             style="cursor:pointer;">
                                            @context.StudentSalutation
                                            @context.StudentFirstName
                                            @context.StudentLastName
                                        </div>

                                        <!-- StudentNumber -->
                                        @if (!string.IsNullOrWhiteSpace(context.StudentNumber))
                                        {
                                            <MudTooltip Text="StudentNumber" Placement="Placement.Bottom">
                                                <div class="d-flex align-items-center gap-1 small text-muted">
                                                    <MudIcon Icon="@Icons.Material.Filled.Person"
                                                             Style="font-size:15px; color:#9e9e9e;" />
                                                    <span style="color:#374151; font-weight:500;">
                                                        @context.StudentNumber
                                                    </span>
                                                </div>
                                            </MudTooltip>
                                        }

                                    </div>
                                </div>
                            </MudTd>
                            <MudTd>
                                <div class="d-flex flex-column gap-1">

                                    <!-- Email -->
                                    @if (!string.IsNullOrWhiteSpace(context.EmailID))
                                    {
                                        <MudTooltip Text="Email">
                                            <div class="d-flex align-items-center gap-2">

                                                <MudIcon Icon="@Icons.Material.Filled.Email"
                                                         Style="font-size:14px;"
                                                         Color="Color.Primary" />

                                                <a href="mailto:@context.EmailID"
                                                   style="font-size:13px; text-decoration:none;"
                                                   class="text-primary">
                                                    @context.EmailID
                                                </a>

                                            </div>
                                        </MudTooltip>
                                    }

                                    <!-- Mobile -->
                                    @if (!string.IsNullOrWhiteSpace(context.MobileNo))
                                    {
                                        <MudTooltip Text="Mobile Number">
                                            <div class="d-flex align-items-center gap-2">

                                                <MudIcon Icon="@Icons.Material.Filled.Phone"
                                                         Style="font-size:14px;"
                                                         Color="Color.Success" />

                                                <a href="tel:@context.MobileNo"
                                                   style="font-size:13px; text-decoration:none;"
                                                   class="text-dark">
                                                    @context.MobileNo
                                                </a>

                                            </div>
                                        </MudTooltip>
                                    }

                                    <!-- Empty -->
                                    @if (string.IsNullOrWhiteSpace(context.EmailID) &&
                                                                        string.IsNullOrWhiteSpace(context.MobileNo))
                                    {
                                        <span class="text-muted" style="font-size:12px;">
                                            No contact info
                                        </span>
                                    }

                                </div>
                            </MudTd>
                            <MudTd>
                                <div class="d-flex flex-column">

                                    <MudTooltip Text="Created By">
                                        <div class="d-flex align-items-center gap-2 fw-semibold">
                                            <MudIcon Icon="@Icons.Material.Filled.Person"
                                                     Style="font-size:14px;"
                                                     Color="Color.Primary" />
                                            @context.CreatedBy
                                        </div>
                                    </MudTooltip>

                                    <MudTooltip Text="Created Date">
                                        <div class="d-flex align-items-center gap-2 text-muted" style="font-size:12px;">
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule"
                                                     Style="font-size:14px;" />
                                            @context.CreatedDate.ToString("dd MMM yyyy")
                                        </div>
                                    </MudTooltip>

                                </div>
                            </MudTd>
                            <MudTd @onclick:stopPropagation="true">
                                <MudTooltip Text="View student data">
                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="@(() => OpenStudentDetails(context))" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <div class="text-end mt-2">
                        <span class="text-primary fw-semibold"
                              style="cursor:pointer;"
                              @onclick="GoToStudents">
                            View More →
                        </span>
                    </div>

                </MudPaper>
            </MudItem>


            @if (CurrentStaffType != StaffType.Marketing)
            {
                <!-- Recent Applications -->
                <MudItem xs="12" Class="mt-4">
                    <MudPaper Class="pa-4">
                        <div class="section-title">Recent Programs</div>

                        <MudTable Items="RecentCourseRequirements" Dense Hover>
                            <HeaderContent>
                                <MudTh Class="table-header">Course</MudTh>
                                <MudTh Class="table-header">Seats</MudTh>
                                <MudTh Class="table-header">Period</MudTh>
                                <MudTh Class="table-header">Status</MudTh>
                            </HeaderContent>

                            <RowTemplate>
                                <MudTd>

                                    @if (!string.IsNullOrWhiteSpace(context.CourseName))
                                    {
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="text-primary fw-medium"
                                                  style="cursor:pointer;">
                                                @context.CourseName
                                            </span>
                                        </div>

                                        <div class="d-flex align-items-center gap-1">
                                            <span>@context.UniversityName</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">N/A</span>
                                    }

                                </MudTd>
                                <MudTd>

                                    @if (context.NoSeats > 0)
                                    {
                                        <span>@context.NoSeats</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">N/A</span>
                                    }

                                </MudTd>
                                <MudTd>

                                    @if (context.ReqStartDate.HasValue && context.ReqEndDate.HasValue)
                                    {
                                        <div class="d-flex flex-column small">

                                            <span>
                                                <span style="width:30px;display:inline-block" class="text-muted">Start</span>
                                                @context.ReqStartDate.Value.ToString("dd MMM yyyy")
                                            </span>

                                            <span>
                                                <span style="width:30px;display:inline-block" class="text-muted">End</span>
                                                @context.ReqEndDate.Value.ToString("dd MMM yyyy")
                                            </span>

                                        </div>
                                    }
                                    else if (context.ReqStartDate.HasValue)
                                    {
                                        <span>
                                            <span class="text-muted me-2">Start</span>
                                            @context.ReqStartDate.Value.ToString("dd MMM yyyy")
                                        </span>
                                    }
                                    else if (context.ReqEndDate.HasValue)
                                    {
                                        <span>
                                            <span class="text-muted me-2">End</span>
                                            @context.ReqEndDate.Value.ToString("dd MMM yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">N/A</span>
                                    }

                                </MudTd>
                                <MudTd>

                                    <div class="d-flex align-items-start">

                                        <MudChip T="string" Size="Size.Small"
                                                 Variant="Variant.Outlined"
                                                 Color="@GetApprovalChipColor(context.ApprovalStatus)"
                                                 Style="min-width:90px; justify-content:center;">

                                            @GetApprovalChipText(context.ApprovalStatus)

                                        </MudChip>

                                    </div>

                                </MudTd>
                            </RowTemplate>
                        </MudTable>

                        <div class="text-end mt-2">
                            <span class="text-primary fw-semibold"
                                  style="cursor:pointer;"
                                  @onclick="GoToCourseRequirement">
                                View More →
                            </span>
                        </div>

                    </MudPaper>
                </MudItem>


            }

        </MudGrid>

    </MudContainer>

</div>
 


@code {


    private StaffType? CurrentStaffType;
    protected override async Task OnInitializedAsync()
    {
        TState.OnChange += OnLanguageChanged;
        await LoadDashboard();
        await LoadDashboardStudents();
        await LoadDashboardRecentCourseRequirements();

        var user = CurrentUserProfileService.GetCurrentUserProfile();
        CurrentStaffType = user.StaffType;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TState.OnChange -= OnLanguageChanged;
    }



    private DashboardDto Dashboard = new DashboardDto();
    private List<DashboardCardDto> DashboardCards = new();

    private async Task LoadDashboard()
    {
        var result = await CommonService.GetDashboard();
        if (result.Data != null)
        {

            Dashboard = result.Data;
            DashboardCards = Dashboard.Cards;
        }
    }


    private string GetMudIcon(string icon)
    {
        return icon switch
        {
            "graduation-cap" => Icons.Material.Filled.School,
            "file" => Icons.Material.Filled.Description,
            "clock" => Icons.Material.Filled.Schedule,
            "check-circle" => Icons.Material.Filled.CheckCircle,
            "times-circle" => Icons.Material.Filled.Cancel,
            _ => Icons.Material.Filled.Info
        };
    }



    private void Navigate(string url)
    {
        if (!string.IsNullOrEmpty(url) && url != "#")
        {
            NavManager.NavigateTo(url);
        }
    }


    private List<StudentRequestDto> RecentStudents = new();
    private async Task LoadDashboardStudents()
    {
        try
        {
            await InvokeAsync(StateHasChanged);

            var filter = new StudentFilterDto
            {
                PageNumber = 1,
                PageSize = 5,   //only latest 5
            };

            var result = await StudentService.GetStudents(filter);

            if (result.Response.Success)
            {
                RecentStudents = result.Data.Items;
            }
            else
            {
                RecentStudents = new();
                Snackbar.Add(result.Response.Message, Severity.Error);
            }
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }


    void OpenStudentDetails(StudentRequestDto student)
    {
        NavManager.NavigateTo(Routes.StudentView.Replace("{Id:long}", student.StudentId.ToString()));
    }


    void GoToStudents()
    {
        NavManager.NavigateTo(Routes.StudentList);
    }



    private List<CourseRequirementRequestDto> RecentCourseRequirements = new();
    private async Task LoadDashboardRecentCourseRequirements()
    {
        try
        {
            await InvokeAsync(StateHasChanged);

            var filter = new CourseRequirementFilterDto
            {
                PageNumber = 1,
                PageSize = 5,   //only latest 5
				IsActive = true,
				//ApprovalStatus = (int)ApprovalStatus.Pending
            };

            var result = await CourseRequirementService.GetCourseRequirement(filter);

            if (result.Response.Success)
            {
                RecentCourseRequirements = result.Data.Items;
            }
            else
            {
                RecentCourseRequirements = new();
                Snackbar.Add(result.Response.Message, Severity.Error);
            }
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }


    void OpenCourseDetails(CourseRequirementRequestDto course)
    {
        //NavManager.NavigateTo(Routes.CourseView.Replace("{Id:long}", course.CourseId.ToString()));
    }


    void GoToCourseRequirement()
    {
        NavManager.NavigateTo(Routes.CourseRequirementList);
    }


    private Color GetApprovalChipColor(int status)
    {
        return status switch
        {
            (int)ApprovalStatus.Approved => Color.Success,
            (int)ApprovalStatus.Rejected => Color.Error,
            _ => Color.Warning
        };
    }

    private string GetApprovalChipText(int status)
    {
        return status switch
        {
            (int)ApprovalStatus.Approved => "Approved",
            (int)ApprovalStatus.Rejected => "Rejected",
            _ => "Pending"
        };
    }
}