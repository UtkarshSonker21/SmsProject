@page "/home"
@page "/dashboard"
@attribute [Authorize]

@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using ScholarshipManagement.DTOs.Common.Settings
@using ScholarshipManagement.Helper.Translations
@using ScholarshipManagement.Services.Common
@using ApexCharts
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject CommonService CommonService
@inject AuthService AuthService
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject TranslationStateService T
@inject TranslationStateService TState


<style>
    .dashboard-card {
        border-radius: 12px;
        height: 110px;
        transition: 0.2s;
    }

        .dashboard-card:hover {
            transform: translateY(-4px);
            transition: 0.2s;
        }

    /* Colors */
    /* .success {
        background: #16a34a;
        color: white;
    }

    .info {
        background: #2563eb;
        color: white;
    }

    .warning {
        background: #f59e0b;
        color: white;
    }

    .danger {
        background: #dc2626;
        color: white;
    } */


    .success {
    background: rgba(22, 163, 74, 0.15);
    color: #16a34a;
    border: 1px solid rgba(22, 163, 74, 0.25);
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 12px rgba(22, 163, 74, 0.15);
}

.info {
    background: rgba(37, 99, 235, 0.15);
    color: #2563eb;
    border: 1px solid rgba(37, 99, 235, 0.25);
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
}

.warning {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.25);
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.15);
}

.danger {
    background: rgba(220, 38, 38, 0.15);
    color: #dc2626;
    border: 1px solid rgba(220, 38, 38, 0.25);
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.15);
}


    .card-title {
        font-size: 13px;
        opacity: 0.8;
    }

    .card-value {
        font-size: 26px;
        font-weight: bold;
    }

    .card-sub {
        font-size: 11px;
        opacity: 0.7;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 10px;
    }
</style>



<!-- Main Content Wrapper -->
<div style="display: flex; flex-direction: column; align-items: flex-start; flex: 1 0 0;">

    <!-- Page Top Section (Header area) -->
    <div style="display: flex; flex-direction: column; align-items: center; align-self: stretch;">

        <!-- Section Title Bar (under Page Top) -->
        <div style="display: flex; height: 64px; justify-content: space-between; align-items: center;
                    align-self: stretch; border-bottom: 1px solid var(--color-border-horizontal-lines, #DBDBDB);
                    background: var(--color-background-main, #FFF);">

            <!-- Left Section (Inside Page Title Bar) -->
            <div style="display: flex; height: 64px; padding: 0 26px; align-items: center;">

                <div style="display: flex; align-items: center;">


                    @* <span class="page-title">
                        @T.T("Dashboard")
                    </span> *@

                    <span class="page-title page-title-uppercase">
                        @T.T("Dashboard")
                    </span>

                </div>

            </div>

            <!-- Right Section (Inside Page Title Bar) -->
            <div style="display: flex; padding: 0 24px; justify-content: flex-end; align-items: center; gap: 14px;">
                <span style="color: var(--color-text-breadcrumbs, #000); font-family: Inter, sans-serif;
                            font-size: 15px; font-style: normal; font-weight: 400; line-height: 20px;
                            text-transform: capitalize; margin-right:25px">
                    @* Total Records : <span id="totalRecords">@TotalRecords</span> *@
                </span>
            </div>

        </div>

    </div>

    <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">

        <!-- KPI CARDS -->
        <MudGrid Class="mb-4">

            @foreach (var card in DashboardCards)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class=@($"pa-4 d-flex align-center justify-space-between dashboard-card {card.Color}")>
                        <div>
                            <div class="card-title">@card.Title</div>
                            <div class="card-value">@card.Value</div>
                            <div class="card-sub">+12% this month</div>
                        </div>
                        <MudIcon Icon="@card.Icon" Size="Size.Large" />
                    </MudPaper>
                </MudItem>
            }

        </MudGrid>

        <!-- CHARTS -->
        <MudGrid Class="mb-4">

            <!-- LEFT: BAR/LINE CHART -->
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4">
                    @* <div class="section-title">Applications Overview</div>

                    <ApexChart TItem="ChartData" Options="lineOptions">

                        <ApexPointSeries TItem="ChartData"
                                         Items="chartData"
                                         Name="Applications"
                                         XValue="@(e => e.Month)"
                                         YValue="@(e => e.Count)" />

                    </ApexChart> *@
                    

                </MudPaper>
            </MudItem>

            <!-- RIGHT: DONUT CHART -->
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4">
                    @* <div class="section-title">Status Distribution</div>

                    <ApexChart TItem="StatusData" Options="barOptions">

                        <ApexPointSeries TItem="StatusData"
                                         Items="statusData"
                                         Name="Applications" Horizontal=true
                                         XValue="@(e => e.Label)"
                                         YValue="@(e => e.Value)" />

                    </ApexChart> *@

                </MudPaper>
            </MudItem>

        </MudGrid>



        <!-- TABLES -->
        <MudGrid>

            <!-- Recent Students -->
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <div class="section-title">Recent Students</div>

                    <MudTable Items="RecentStudents" Dense Hover>
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Country</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>

                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.Country</MudTd>
                            <MudTd>
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Style="min-width:100px; justify-content:center;">
                                    @context.Status
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                </MudPaper>
            </MudItem>

            <!-- Recent Applications -->
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <div class="section-title">Recent Applications</div>

                    <MudTable Items="RecentApplications" Dense Hover>
                        <HeaderContent>
                            <MudTh>Student</MudTh>
                            <MudTh>Program</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>

                        <RowTemplate>
                            <MudTd>@context.Student</MudTd>
                            <MudTd>@context.Program</MudTd>
                            <MudTd>
                                <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Style="min-width:100px; justify-content:center;">
                                    @context.Status
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                </MudPaper>
            </MudItem>

        </MudGrid>

    </MudContainer>

</div>
 


@code {



    protected override async Task OnInitializedAsync()
    {
        TState.OnChange += OnLanguageChanged;
        await LoadDashboard();
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TState.OnChange -= OnLanguageChanged;
    }


    List<CardModel> DashboardCards = new()
    {
        new("Total Students", 1200, "success", Icons.Material.Filled.School),
        new("Applications", 320, "info", Icons.Material.Filled.Description),
        new("Pending", 86, "warning", Icons.Material.Filled.Pending),
        new("Rejected", 24, "danger", Icons.Material.Filled.Cancel)
    };

    List<Student> RecentStudents = new()
    {
        new("Amit Sharma", "India", "Approved"),
        new("John Doe", "UK", "Pending"),
        new("Ali Khan", "UAE", "Approved"),
        new("Sara Lee", "USA", "Rejected")
    };

    List<Application> RecentApplications = new()
    {
        new("Amit Sharma", "MBA", "Pending"),
        new("John Doe", "BSc IT", "Approved"),
        new("Ali Khan", "Engineering", "Pending"),
        new("Sara Lee", "Medical", "Rejected")
    };

    public record CardModel(string Title, int Value, string Color, string Icon);
    public record Student(string Name, string Country, string Status);
    public record Application(string Student, string Program, string Status);






    private DashboardDto dashboard = new DashboardDto();
    private async Task LoadDashboard()
    {
        var result = await CommonService.GetDashboard();
        dashboard = result.Data;
    }




}