    protected override async Task OnInitializedAsync()
    {
        var isLoggedIn = await Auth.IsUserLoggedIn();

        if (isLoggedIn)
        {
            Nav.NavigateTo(Routes.Dashboard, replace: true);
        }
        else
        {
            Nav.NavigateTo(Routes.Login, replace: true);
        }
    }


}
