@using MudBlazor
@using ScholarshipManagement.Helper.Translations
@using ScholarshipManagement.Pages.Common.Shared
@using ScholarshipManagement.Services.Common
@using static ScholarshipManagement.Helper.Constant
@inject NavigationManager Nav
@inject AuthService Auth
@inject TranslationManager T
@layout EmptyLayout

