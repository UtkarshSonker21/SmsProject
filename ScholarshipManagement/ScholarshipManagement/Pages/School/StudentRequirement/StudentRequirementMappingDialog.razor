@using MudBlazor
@using MudBlazor.Components
@using ScholarshipManagement.DTOs
@using ScholarshipManagement.DTOs.Common
@using ScholarshipManagement.DTOs.Common.HrStaff
@using ScholarshipManagement.DTOs.School.StudentRequirements
@using ScholarshipManagement.DTOs.School.Students
@using ScholarshipManagement.DTOs.SuperAdmin.UsersMenu
@using ScholarshipManagement.DTOs.University.CourseRequirement
@using ScholarshipManagement.DTOs.University.MasterDocuments
@using ScholarshipManagement.DTOs.University.MasterUniversity
@using ScholarshipManagement.Services.Common
@using ScholarshipManagement.Services.School
@using ScholarshipManagement.Services.SuperAdmin
@using ScholarshipManagement.Services.University
@using ScholarshipManagement.Helper.Enums
@inject UniversityDocumentService UniversityDocumentService
@inject UniversityService UniversityService
@inject StudentRequirementService StudentRequirementService
@inject CourseRequirementService CourseRequirementService
@inject StudentService StudentService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject UsersMenuService UsersMenuService
@inject CommonService CommonService


<style>
    /* .file-input-overlay {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    } */

    .icon-upload-wrapper {
        position: relative;
        display: inline-block;
    }

        .icon-upload-wrapper .file-input-overlay {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

</style>


<MudDialog MaxWidth="MaxWidth.Large" FullWidth="true">

    <DialogContent>

        <!-- ⭐ Paper wrapper (same as page) -->
        <MudPaper Class="pa-1" Elevation="1">

            <MudForm @ref="_form" Model="@StdReqMap">

                <MudGrid Spacing="3">

                    <MudItem xs="12" md="6">
                        <MudSelect T="long?"
                                   Label="University"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Required="true"
                                   RequiredError="University is required"
                                   Value="SelectedUniversityId"
                                   ValueChanged="OnUniversityChanged">

                            <MudSelectItem T="long?" Value="null">
                                -- Select University --
                            </MudSelectItem>

                            @foreach (var c in Universities)
                            {
                                <MudSelectItem T="long?" Value="c.UniversityId">
                                    @c.UniversityName
                                </MudSelectItem>
                            }

                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudSelect T="long?"
                                   Label="Course Requirement"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Required="true"
                                   RequiredError="Requirement is required"
                                   Value="SelectedReqId"
                                   ValueChanged="OnReqChanged">

                            <!-- Default placeholder -->
                            <MudSelectItem T="long" Value="0">
                                -- Select Course --
                            </MudSelectItem>

                            @foreach (var c in Requirements)
                            {
                                <MudSelectItem T="long?" Value="c.ReqId">
                                    @c.CourseName
                                </MudSelectItem>
                            }

                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12">
                        <MudSelect T="long"
                                   Label="Student"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Required="true"
                                   RequiredError="Student is required"
                                   @bind-Value="StdReqMap.StudentID">

                            <!-- Default placeholder -->
                            <MudSelectItem T="long" Value="0">
                                -- Select Student --
                            </MudSelectItem>

                            @foreach (var c in Students)
                            {
                                <MudSelectItem T="long" Value="@(c.StudentId ?? 0)">
									@c.StudentSalutation @c.StudentFirstName @c.StudentLastName : @c.StudentNumber
                                </MudSelectItem>
                            }

                        </MudSelect>
                    </MudItem>


                    <MudItem xs="12">
                        <MudPaper Class="pa-3" Elevation="0" Style="border-radius:8px;">

                            <!-- Header -->
                            <div class="d-flex align-items-center mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Description"
                                         Class="me-2"
                                         Color="Color.Primary" />
                                <MudText Typo="Typo.subtitle1" Class="fw-bold">
                                    Student Documents
                                </MudText>
                            </div>

                            @if (RequiredDocuments.Any())
                            {
                                <MudTable Items="RequiredDocuments"
                                          Dense="true"
                                          Hover="true"
                                          Bordered="true"
                                          Striped="true">

                                    <HeaderContent>
                                        <MudTh>Type</MudTh>
                                        <MudTh>Document Name</MudTh>
                                        <MudTh Style="width:140px;">Action</MudTh>
                                    </HeaderContent>

                                    <RowTemplate>

                                        <!-- ✅ Document Type -->
                                        <MudTd>
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="Color.Primary"
                                                     Variant="Variant.Outlined" Style="min-width:80px; justify-content:center;">
                                                @context.DocType
                                            </MudChip>
                                        </MudTd>

                                        <!-- ✅ Document Name -->
                                        <MudTd>@context.DocName</MudTd>

                                        <!-- ✅ Actions -->
                                        <MudTd>



                                            @if (context.IsUploaded)
                                            {
                                                <!-- 👁 VIEW -->
                                                <MudTooltip Text="View File">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                                   Color="Color.Primary"
                                                                   Size="Size.Small"
                                                                   OnClick="@(() => OpenFile(context.FileUrl))" />
                                                </MudTooltip>

                                                <!-- 🔄 REPLACE -->
                                                <MudTooltip Text="Replace File">
        
                                                    <div class="icon-upload-wrapper">

                                                        <MudTooltip Text="Upload File">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Update"
                                                                           Color="Color.Success"
                                                                           Size="Size.Small" />
                                                        </MudTooltip>

                                                        <!-- IMPORTANT: OUTSIDE the button -->
                                                        <InputFile OnChange="e => UploadFile(context.StdReqId, context.MasterDocId, e.File)"
                                                                   accept=".pdf,.png,.jpg,.jpeg"
                                                                   class="file-input-overlay" title="" />

                                                    </div>

                                                </MudTooltip>
                                            }
                                            else
                                            {
                                                <!-- 👁 VIEW (Disabled) -->
                                                <MudTooltip Text="File not uploaded yet">
                                                    <span>
                                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                                       Disabled="true"
                                                                       Color="Color.Default"
                                                                       Size="Size.Small"/>
                                                    </span>
                                                </MudTooltip>

                                                <!-- ⬆ UPLOAD -->
                                                <MudTooltip Text="Upload File">
                                   
                                                    <div class="icon-upload-wrapper">

                                                        <MudTooltip Text="Upload File">
                                                            <MudIconButton Icon="@Icons.Material.Filled.CloudUpload"
                                                                           Color="Color.Success"
                                                                           Size="Size.Small" />
                                                        </MudTooltip>

                                                        <!-- IMPORTANT: OUTSIDE the button -->
                                                        <InputFile OnChange="e => UploadFile(context.StdReqId, context.MasterDocId, e.File)"
                                                                   accept=".pdf,.png,.jpg,.jpeg"
                                                                   class="file-input-overlay" title="" />

                                                    </div>

                                                </MudTooltip>
                                            }


                                        </MudTd>

                                    </RowTemplate>

                                </MudTable>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Dense="true">
                                    Please select university and requirement to load documents.
                                </MudAlert>
                            }

                        </MudPaper>
                    </MudItem>


                    <MudItem xs="12">
                        <div class="d-flex justify-end gap-2" style="margin:10px 0;">
                            <button @onclick="Save" class="dialog-btn" type="button">Save</button>
                            <button @onclick="Cancel" class="dialog-btn" type="button">Cancel</button>
                        </div>
                    </MudItem>


                </MudGrid>

            </MudForm>

        </MudPaper>

    </DialogContent>

</MudDialog>



@code {

    [CascadingParameter]
    private IMudDialogInstance DialogReference { get; set; } = default!;

    [Parameter]
    public StudentRequirementMappingDto StdReqMap { get; set; } = new();


    private string Title = "Apply To Requirement";
    private List<CourseRequirementRequestDto> Requirements = new();
    private List<StudentRequestDto> Students = new();

    private Guid UploadSeesionId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await InvokeAsync(StateHasChanged);



            await GetStudents();
            await GetUniversities();
            // await GetDocuments();

            if (StdReqMap.StudentReqID is null or 0)
            {
                Title = "Apply To Requirement";
                UploadSeesionId = Guid.NewGuid();
            }
            else
            {
                Title = "Apply To Requirement";

                SelectedUniversityId = StdReqMap.UniversityId;
                SelectedReqId = StdReqMap.ReqId;

                if (SelectedUniversityId.HasValue)
                {
                    await GetRequirements(SelectedUniversityId.Value);
                }

                // Load documents for edit
                if (StdReqMap.StudentReqID.HasValue && StdReqMap.ReqId > 0)
                {
                    await GetRequiredDcouments(StdReqMap.StudentReqID, StdReqMap.ReqId);
                }


                // FORCE UI REFRESH
                await InvokeAsync(StateHasChanged);
            }

        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private MudForm? _form;
    private async Task Save()
    {
        try
        {
            await _form!.Validate();

            if (!_form.IsValid || !SelectedUniversityId.HasValue)
                return;

            if (StdReqMap.StudentID == 0)
            {
                Snackbar.Add("Please select student", Severity.Error);
                return;
            }

            if (AllUploaded != true)
            {
                Snackbar.Add("Please upload all required documents", Severity.Error);
                return;
            }


            StdReqMap.UniversityId = SelectedUniversityId.Value;
			StdReqMap.UploadSessionId = UploadSeesionId;

            var result = StdReqMap.StudentReqID is null or 0
                ? await StudentRequirementService.CreateStudentRequirementMapAsync(StdReqMap)
                : await StudentRequirementService.UpdateStudentRequirementMapAsync(StdReqMap);


            // Always show backend message
            Snackbar.Add(
                result.Message,
                result.Success ? Severity.Success : Severity.Error
            );

            // Close dialog only if success
            if (result.Success)
            {
                DialogReference.Close(DialogResult.Ok(result));
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Something went wrong while saving. Please try again.", Severity.Error);
            Cancel();
        }
    }


    private void Cancel()
    {
        DialogReference.Cancel();
    }


    private List<UniversityRequestDto> Universities = new();
    private async Task GetUniversities()
    {
        var result = await UniversityService.GetMasterUniversity(new UniversityFilterDto
        {
            PageNumber = 1,
            PageSize = 0
        }
        );


        if (result.Response.Success)
        {
            Universities = result.Data.Items;
        }
        else
        {
            Snackbar.Add(result.Response.Message, Severity.Warning);
        }
        await InvokeAsync(StateHasChanged);
    }


    private long? SelectedUniversityId { get; set; } = null;

    private async Task OnUniversityChanged(long? universityId)
    {
        SelectedUniversityId = universityId;

        if (universityId.HasValue)
        {
            await GetRequirements(universityId.Value);
        }
    }

    private async Task GetRequirements(long universityId)
    {
        var result = await CourseRequirementService.GetCourseRequirement(new CourseRequirementFilterDto
        {
            PageNumber = 1,
            PageSize = 0,
            ApprovalStatus = (int)ApprovalStatus.Approved,
			UniversityId = universityId
        });


        if (result.Response.Success)
        {
            Requirements = result.Data.Items;
        }
        else
        {
            Snackbar.Add(result.Response.Message, Severity.Warning);
        }
        await InvokeAsync(StateHasChanged);
    }


    private long? SelectedReqId { get; set; } = null;

    private async Task OnReqChanged(long? reqID)
    {
        SelectedReqId = reqID;

        if (reqID.HasValue)
        {
            StdReqMap.ReqId = reqID.Value;

            await GetRequiredDcouments(StdReqMap.StudentReqID, reqID.Value);

        }
    }


    private int TotalDocs => RequiredDocuments?.Count ?? 0;

    private int UploadedDocs => RequiredDocuments?.Count(x => x.IsUploaded) ?? 0;

    private int MissingDocs => TotalDocs - UploadedDocs;

    private bool AllUploaded => TotalDocs > 0 && MissingDocs == 0;

    private List<StudentDocumentDto> RequiredDocuments = new();

    private async Task GetRequiredDcouments(long? studentReqId , long reqId)
    {
        // var ok = await StudentRequirementService.GetDocumentsAsync(studentReqId);
        var ok = await StudentRequirementService.GetDocumentsAsync(studentReqId,UploadSeesionId, reqId);

        if (ok.Response.Success)
        {
            RequiredDocuments = ok.Data;

            await InvokeAsync(StateHasChanged);
        }
        else
        {
            Snackbar.Add(ok.Response.Message, Severity.Error);
        }
    }



    private async Task GetStudents()
    {
        var result = await StudentService.GetStudents(new StudentFilterDto
        {
            PageNumber = 1,
            PageSize = 0
        });


        if (result.Response.Success)
        {
            Students = result.Data.Items;
        }
        else
        {
            Snackbar.Add(result.Response.Message, Severity.Warning);
        }
        await InvokeAsync(StateHasChanged);
    }



    private async Task UploadFile(long? studentReqId, long masterDocId, IBrowserFile file)
    {
        if (StdReqMap.StudentID == 0)
        {
            Snackbar.Add("Please select student",Severity.Error );
            return;
        }

        // var result = await StudentRequirementService.UploadDocumentAsync(studentReqId, masterDocId, file);
        var result = await StudentRequirementService.UploadDocumentAsync(UploadSeesionId,studentReqId, StdReqMap.StudentID, masterDocId, file);

        // Always show backend message
        Snackbar.Add(
            result.Message,
            result.Success ? Severity.Success : Severity.Error
        );

        // await GetRequiredDcouments(studentReqId);

        if (StdReqMap.ReqId > 0)
            await GetRequiredDcouments(StdReqMap.StudentReqID, StdReqMap.ReqId);

        await InvokeAsync(StateHasChanged);
    }



    async Task OpenFile(string url)
    {
        if (!string.IsNullOrEmpty(url))
        {
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
    }


