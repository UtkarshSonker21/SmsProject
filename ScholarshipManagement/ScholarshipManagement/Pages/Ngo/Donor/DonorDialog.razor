@using MudBlazor
@using MudBlazor.Components
@using ScholarshipManagement.DTOs
@using ScholarshipManagement.DTOs.Common
@using ScholarshipManagement.DTOs.Ngo.Donor
@using ScholarshipManagement.Services.Ngo
@inject DonorService DonorService
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar


<MudDialog MaxWidth="MaxWidth.Large" FullWidth="true">

    <DialogContent>

        <!-- ⭐ Paper wrapper (same as page) -->
        <MudPaper Class="pa-1" Elevation="1">

            <MudForm @ref="_form" Model="@Donor">

                <MudGrid Spacing="3">

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
									  Label="Donor Name"
                                      @bind-Value="Donor.DonorName"
                                      For="@(() => Donor.DonorName)"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
									  Label="Donor Code"
                                      @bind-Value="Donor.DonorCode"
                                      For="@(() => Donor.DonorCode)"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Donor Email"
                                      @bind-Value="Donor.DonorEmail" 
                                      For="@(() => Donor.DonorEmail)"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Donor Phone"
                                      @bind-Value="Donor.DonorPhone"
                                      For="@(() => Donor.DonorPhone)"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Remarks"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="4"
                                      AutoGrow="true"
                                      @bind-Value="Donor.Remarks"
                                      For="@(() => Donor.Remarks)" />
                    </MudItem>

                    <MudItem xs="12">
                        <div class="d-flex justify-end gap-2" style="margin:10px 0;">
                            <button @onclick="Save" class="dialog-btn" type="button">Save</button>
                            <button @onclick="Cancel" class="dialog-btn" type="button">Cancel</button>
                        </div>
                    </MudItem>

                </MudGrid>

            </MudForm>

        </MudPaper>

    </DialogContent>

</MudDialog>



@code {

    [CascadingParameter]
    private IMudDialogInstance DialogReference { get; set; } = default!;

    [Parameter]
    public DonorRequestDto Donor { get; set; } = new();


    protected override async Task OnInitializedAsync()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private MudForm? _form;
    private async Task Save()
    {
        try
        {
            await _form!.Validate();

            if (!_form.IsValid)
                return;


            var result = Donor.DonorId is null or 0
                ? await DonorService.AddDonor(Donor)
                : await DonorService.UpdateDonor(Donor);


            // Always show backend message
            Snackbar.Add(
                result.Message,
                result.Success ? Severity.Success : Severity.Error
            );

            // Close dialog only if success
            if (result.Success)
            {
                DialogReference.Close(DialogResult.Ok(result));
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Something went wrong while saving. Please try again.", Severity.Error);
            Cancel();
        }
    }


    private void Cancel()
    {
        DialogReference.Cancel();
    }



}
