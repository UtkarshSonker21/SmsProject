                     Class="blue-hover-grid"
                     Items="Items" FixedHeader="true" Height="550px"
                     ColumnResizeMode="ResizeMode.None" Id="myGrid"
                     Selection="DataGridSelection.Single">

            <Columns>

                <TemplateColumn Title="Student Information"
