                                    @(string.IsNullOrWhiteSpace(ctx.Item.DocStatus) ? "N/A" : ctx.Item.DocStatus)

                                </MudChip>
                            </div>
                        </CellTemplate>

                    </TemplateColumn>

                    <TemplateColumn Title="Awarding Status"
                                    HeaderClass="fw-bold"
                                    HeaderStyle="width:150px; min-width:150px; max-width:150px;"
                                    CellStyle="width:150px; min-width:150px; max-width:150px;"
                                    Hideable="true">

                        <CellTemplate Context="ctx">

                            <div class="d-flex flex-column align-items-start">

                                <MudChip Size="Size.Small"
