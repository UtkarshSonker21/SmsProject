                    <CellTemplate Context="ctx">

                        <div class="d-flex align-items-center gap-1">

                            <!-- Icon -->
                            @* <MudIcon Icon="@Icons.Material.Filled.School"
                                     Color="Color.Primary"
                                     Style="font-size:14px;" /> *@

                            <!-- Text -->
