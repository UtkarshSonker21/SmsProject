    <!-- 🔹 Pagination -->
    <div class="d-flex align-items-center justify-content-between px-4 mb-3"
         style="height: 50px; background: #fff; margin-top:10px;">

        <!-- Left Side (Empty but keeps even spacing like your layout) -->
        <div style="display: flex; align-items: center; gap: 10px; font-family: Inter, sans-serif; font-size: 13px; margin-right:10px;">
            <label class="me-2">Results per Page:</label>

            <select id="pageSize" class="form-select"
                    style="width: 70px; height: 32px; font-size: 13px; padding: 2px 6px;"
                    @onchange="OnPageSizeChanged">

                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="500">500</option>
            </select>
        </div>



        <!-- Center: Custom Pagination (Your Styled UI) -->
        <div class="d-flex align-items-center gap-3">

            <button @onclick="PrevPage" disabled="@IsPrevDisabled" class="pg-btn">◀ PREV</button>

            <span>Page</span>

            <input readonly value="@PageNumber" class="pg-input" />

            <span>of @TotalPages</span>

            <button @onclick="NextPage" disabled="@IsNextDisabled" class="pg-btn">NEXT ▶</button>

        </div>

    </div>

</div>


@code {

    int PageNumber = 1;       // current page
    int PageSize = 25;        // rows per page
    int TotalRecords = 0;     // total records returned by API
    int TotalPages => (int)Math.Ceiling((double)TotalRecords / PageSize); // calculated
    private List<EnrolledStudentDto> Items = new();
    private MudDataGrid<EnrolledStudentDto>? dataGrid;
    private StudentFilterDto Filter = new StudentFilterDto();

    private StaffType? CurrentStaffType;
    bool canView => PermissionService.CanView("course-enrollment") || PermissionService.CanView("enrolled-students");
    bool canAdd => PermissionService.CanInsert("course-enrollment") || PermissionService.CanInsert("enrolled-students");
    bool canEdit => PermissionService.CanUpdate("course-enrollment") || PermissionService.CanUpdate("enrolled-students");
    bool canDelete => PermissionService.CanDelete("course-enrollment") || PermissionService.CanDelete("enrolled-students");


    [Parameter]
    public long reqId { get; set; }


    protected override async Task OnInitializedAsync()
    {
        if (!canView)
        {
            Navigation.NavigateTo(Routes.Dashboard);
        }

        var user = CurrentUserProfileService.GetCurrentUserProfile();
        CurrentStaffType = user.StaffType;

        await LoadData(Filter);
        //await GetDocuments();
    }


    // global search
    private string _search = "";
    private bool _searchApplied = false;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplySearch();
        }
    }

    private async Task ApplySearch()
    {
        Filter.SearchText = string.IsNullOrWhiteSpace(_search)
            ? null
            : _search.Trim();

        Filter.PageNumber = 1;
        PageNumber = 1;
        _searchApplied = true;

        await LoadData(Filter);
    }

    private async Task ClearSearch()
    {
        _search = string.Empty;
        Filter.SearchText = null;
        Filter.PageNumber = 1;
        PageNumber = 1;
        _searchApplied = false;

        await LoadData(Filter);
    }


    private bool _loading = false;
    private async Task LoadData(StudentFilterDto filter)
    {
        try
        {
            _loading = true;                 // start loading
            await InvokeAsync(StateHasChanged); // refresh UI immediately if needed



            var result = reqId == 0 ?
                         await CourseRequirementService.GetAllEnrolledStudents(filter) :
                         await CourseRequirementService.GetEnrolledStudentsByReqId(reqId, filter);

            if (result.Response.Success)
            {
                // Data already deserialized in service
                Items = result.Data.Items;

                if (CurrentStaffType == StaffType.Ngo && reqId == 0)
                {
                    Items = Items.Where(x => x.AwardingStatus == "Awarded").ToList();
                }

                if (CurrentStaffType == StaffType.Marketing && reqId == 0)
                {
                    Items = Items.Where(x => x.AwardingStatus == "Awarded" && x.SponsoredStatus == "Sponsored").ToList();
                }

                TotalRecords = result.Data.TotalCount;
            }
            else
            {
                // Always show backend message
                Items = result.Data.Items;
                Snackbar.Add(result.Response.Message, Severity.Error);
            }

        }
        finally
        {
            _loading = false;                // finished loading
            await InvokeAsync(StateHasChanged); // update UI
        }
    }


    // for drop down
    private int GridKey = 1;
    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var newSize))
            return;

        PageNumber = 1;
        PageSize = newSize;

        GridKey++;  // <<<<< IMPORTANT (forces new DataGrid instance)

        if (dataGrid is null)
            return;   //  Prevents the crash

        Filter.PageSize = PageSize;
        Filter.PageNumber = PageNumber;
        await LoadData(Filter);

        StateHasChanged();
    }


    // hide / show coloumns
    private bool showColumnsPopup = false;
    private string columnFilter = "";
    private List<Column<EnrolledStudentDto>> allColumns = new();

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            if (dataGrid is null)
                return;   //  Prevents the crash

            allColumns = dataGrid.RenderedColumns.ToList();
            StateHasChanged();
        }
    }

    private void ToggleColumnsPopup()
    {
        showColumnsPopup = !showColumnsPopup;
    }

    private void ClosePopup()
    {
        showColumnsPopup = false;
    }

    private async Task ToggleColumn(Column<EnrolledStudentDto> col, bool makeVisible)
    {
        if (makeVisible)
            await col.ShowAsync();
        else
            await col.HideAsync();

        //col.Hidden = makeVisible;   // sync checkbox state
        StateHasChanged();
    }


    // pagination btns
    bool IsPrevDisabled => PageNumber <= 1;
    private async Task PrevPage()
    {
        if (PageNumber > 1)
        {
            PageNumber--;
            Filter.PageNumber = PageNumber;
            await LoadData(Filter);
        }
    }

    bool IsNextDisabled => PageNumber >= TotalPages;
    private async Task NextPage()
    {
        if (PageNumber < TotalPages)
        {
            PageNumber++;
            Filter.PageNumber = PageNumber;
            await LoadData(Filter);
        }
    }


    void OpenStudentDetails(EnrolledStudentDto dto)
    {
        var url = Routes.EnrolledStudentData
            .Replace("{stdId:long}", dto.StudentId.ToString())
            .Replace("{reqId:long}", dto.ReqId.ToString());

        Navigation.NavigateTo(url);
    }



    private string GetGenderText(int? gender)
    {
        return gender switch
        {
            1 => "Male",
            2 => "Female",
            3 => "Other",
            _ => "-"
        };
    }

    private Color GetGenderColor(int? gender)
    {
        return gender switch
        {
            1 => Color.Primary,   // Male
            2 => Color.Secondary, // Female
            3 => Color.Info,      // Other
            _ => Color.Default
        };
    }


    private Color GetSponsoredColor(string? status)
    {
        return status?.Trim().ToLower() switch
        {
            "sponsored" => Color.Success,     // Green
            "rejected" => Color.Error,        // Red
            "in process" => Color.Warning,    // yellow
            _ => Color.Default                // Default
        };
    }


    string GetDomain(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return "";

        try
        {
            var uri = new Uri(url);
            return uri.Host.Replace("www.", "");
        }
        catch
        {
            return url;
        }
    }



    private void GoBack()
    {
        Navigation.NavigateTo(Routes.Enrollments);
    }


    private Color GetDocStatusColor(string? status)
    {
        return status?.Trim().ToLower() switch
        {
            "accepted" => Color.Success,     // Green
            "rejected" => Color.Error,       // Red
            "in process" => Color.Warning,   // Yellow
            _ => Color.Default               // Grey (fallback)
        };
    }


    private Color GetAwardingStatusColor(string? status)
    {
        return status?.Trim().ToLower() switch
        {
            "awarded" => Color.Success,       // Green
            "rejected" => Color.Error,        // Red
            "in process" => Color.Warning,    // Yellow
            _ => Color.Default                // Grey
        };
    }



    private CourseRequirementRequestDto Req { get; set; } = new();

    private async Task GetReqById(long reqID)
    {
        var resultReq = await CourseRequirementService.GetCourseRequirementById(reqID);


        if (resultReq.Response.Success)
        {
            Req = resultReq.Data ?? new CourseRequirementRequestDto();

        }
        else
        {
            Snackbar.Add(resultReq.Response.Message, Severity.Error);
        }

        await InvokeAsync(StateHasChanged);

    }


}


