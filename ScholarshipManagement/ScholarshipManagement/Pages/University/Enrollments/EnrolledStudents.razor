                                         Color="@GetAwardingStatusColor(ctx.Item.AwardingStatus)"
                                         Style="min-width:90px; justify-content:center;">

                                    @(
                                                                    string.IsNullOrWhiteSpace(ctx.Item.AwardingStatus)
                                                                    ? "N/A"
                                                                    : ctx.Item.AwardingStatus
