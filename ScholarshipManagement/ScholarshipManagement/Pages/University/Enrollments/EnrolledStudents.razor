                                      style="font-size:13px; max-width:180px;">
                                    @ctx.Item.SchoolName
                                </span>

                                <!-- Short Name -->
                                @* @if (!string.IsNullOrWhiteSpace(ctx.Item.ShortName))
                                {
                                    <span class="text-muted"
                                          style="font-size:11px;">
                                        @ctx.Item.ShortName
                                    </span>
                                } *@

