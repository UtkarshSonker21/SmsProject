    private async Task DeleteCourseType(CourseTypeRequestDto dto)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Are you sure you want to delete '{dto.CourseTypeName}'?" }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm Delete", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && dto.CourseTypeId.HasValue)
        {
            var response = await CourseTypeService.DeleteCourseType(dto.CourseTypeId.Value);

            Snackbar.Add(
                response.Message,
                response.Success ? Severity.Success : Severity.Error
            );

            if (response.Success)
            {
                PageNumber = 1;
                PageSize = 25;
                var filter = new CourseTypeFilterDto();
                await LoadData(filter);
            }
        }

    }


