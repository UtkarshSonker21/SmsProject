    private ApprovalRequestDto approvalRequestDto = new ApprovalRequestDto();
    private async Task ApproveCourseTypeAsync(CourseTypeRequestDto dto)
    {
        var parameters = new DialogParameters
        {
            { "Message", $"Are you sure you want to approve / reject '{dto.CourseTypeName}' from '{dto.UniversityName}'?" }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<ApprovalDialog>("Confirm Approval", parameters, options);

        // dialog returns 1 for approve, 2 for reject
        var result = await dialog.Result;

        if (result != null && result.Data is int selectedStatus && !result.Canceled && dto.CourseTypeId.HasValue)
        {
            approvalRequestDto.EntityId = dto.CourseTypeId.Value;
            approvalRequestDto.ApprovalStatus = selectedStatus;

            var response = await ApprovalService.ApproveCourseType(approvalRequestDto);

            Snackbar.Add(response.Message, response.Success ? Severity.Success : Severity.Error);

            if (response.Success)
            {
                PageNumber = 1;
                PageSize = 25;
                var filter = new CourseTypeFilterDto();
                await LoadData(filter);
            }
        }
    }



    private Color GetApprovalChipColor(int status)
    {
        return status switch
        {
            (int)ApprovalStatus.Approved => Color.Success,
            (int)ApprovalStatus.Rejected => Color.Error,
            _ => Color.Warning
        };
    }

    private string GetApprovalChipText(int status)
    {
        return status switch
        {
            (int)ApprovalStatus.Approved => "Approved",
            (int)ApprovalStatus.Rejected => "Rejected",
            _ => "Pending"
        };
    }




    private ApprovalStatus? SelectedStatus = null; // null = All
    private int _activeTabIndex = 0;

    private async Task OnTabChanged(int index)
    {
        _activeTabIndex = index;

        SelectedStatus = index switch
        {
            1 => ApprovalStatus.Pending,
            2 => ApprovalStatus.Approved,
            3 => ApprovalStatus.Rejected,
            _ => null
        };

        // Reset paging when tab changes
        PageNumber = 1;
        PageSize = 25;
        TotalRecords = 0;

        var filter = new CourseTypeFilterDto
        {
            PageNumber = PageNumber,
            PageSize = PageSize,
            ApprovalStatus = SelectedStatus.HasValue ? (int)SelectedStatus.Value : null,
            SearchText = _search              // if you have search
        };

        await LoadData(filter);
    }



